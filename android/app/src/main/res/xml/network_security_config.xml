<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block all cleartext (HTTP) traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- System CAs only — no user-installed CAs -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>