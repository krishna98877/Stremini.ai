<?xml version="1.0" encoding="utf-8"?>
<!-- Medium-size centered connectors panel. Black bg, glassmorphic white cards. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/connectors_panel"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/panel_bg_dark"
    android:elevation="16dp"
    android:clipToOutline="true"
    android:padding="16dp">

    <!-- Header (compact) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_connectors"
            android:tint="#38BDF8"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Automations"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_composio_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 services"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:layout_marginEnd="12dp" />

        <ImageView
            android:id="@+id/btn_close_connectors"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#9CA3AF"
            android:padding="4dp"
            android:contentDescription="Close"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/composio_search_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/search_bg_dark"
        android:padding="10dp"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_menu_search"
            android:tint="#6B7280"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/composio_search_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search services…"
            android:textColorHint="#6B7280"
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:paddingStart="0dp"
            android:paddingEnd="8dp" />

        <TextView
            android:id="@+id/composio_search_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Info banner (hidden by default, shown when Composio not configured) -->
    <LinearLayout
        android:id="@+id/composio_connect_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_bg_translucent"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_composio"
            android:tint="#38BDF8"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tap Connect to link your account."
            android:textColor="#9CA3AF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Scrollable services grid (3 columns) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="380dp"
        android:fadeScrollbars="true"
        android:scrollbars="vertical"
        android:paddingBottom="4dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/services_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>
