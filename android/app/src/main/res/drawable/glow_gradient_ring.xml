<?xml version="1.0" encoding="utf-8"?>
<!-- Bubble background: circular layers, all sized to fit within the 68dp View
     (previously the outer halo was 72dp which got clipped to a 68dp SQUARE,
     making the bubble look square instead of round). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow halo (sized to fit View, no clipping) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1A3A5C"/>
            <size android:width="68dp" android:height="68dp"/>
        </shape>
    </item>

    <!-- Cyan ring -->
    <item
        android:top="2dp" android:bottom="2dp"
        android:left="2dp" android:right="2dp">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#23A6E2"/>
            <solid android:color="#000000"/>
            <size android:width="64dp" android:height="64dp"/>
        </shape>
    </item>

    <!-- Inner dark circle (logo area) -->
    <item
        android:top="5dp" android:bottom="5dp"
        android:left="5dp" android:right="5dp">
        <shape android:shape="oval">
            <solid android:color="#0A0A0A"/>
            <size android:width="58dp" android:height="58dp"/>
        </shape>
    </item>

</layer-list>
