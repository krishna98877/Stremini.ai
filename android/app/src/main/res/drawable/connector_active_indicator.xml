<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow -->
    <item
        android:left="-3dp"
        android:top="-3dp"
        android:right="-3dp"
        android:bottom="-3dp">
        <shape android:shape="oval">
            <solid android:color="#00f6ff" />
        </shape>
    </item>

    <!-- Inner dot (8dp visible) -->
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="#00f6ff" />
        </shape>
    </item>

</layer-list>