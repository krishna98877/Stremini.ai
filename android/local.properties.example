# Stremini AI — local.properties template
# Copy this file to local.properties and fill in the values:
#   cp local.properties.example local.properties

# Flutter SDK path (set by Flutter CLI automatically)
# flutter.sdk=/path/to/flutter/sdk

# Composio consumer key (embedded at build time)
# Replace with your real key from https://app.composio.dev/
# DO NOT commit your real local.properties file — it is gitignored.
composio.consumer.key=ck__YOUR_COMPOSIO_KEY_HERE