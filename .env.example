# Stremini AI — environment variables template
# ──────────────────────────────────────────────────────────────────────────
# Copy to `.env` (gitignored) and fill in your own values, OR set these as
# real environment variables in your CI/CD pipeline.
#
# Both `android/local.properties` AND environment variables are read by
# `android/app/build.gradle.kts` — local.properties takes priority.
#
# DO NOT commit a real .env file. See SECURITY.md.
# ──────────────────────────────────────────────────────────────────────────

# Required — without these, AI chat and automation won't work
GROQ_API_KEY=
COMPOSIO_CONSUMER_KEY=

# Composio auth_config_id per service (find in Composio dashboard → Auth Configs)
AUTH_CONFIG_GITHUB=
AUTH_CONFIG_GMAIL=
AUTH_CONFIG_INSTAGRAM=
AUTH_CONFIG_FACEBOOK=
AUTH_CONFIG_WHATSAPP=
AUTH_CONFIG_GOOGLEDRIVE=
AUTH_CONFIG_DISCORD=
AUTH_CONFIG_LINKEDIN=
AUTH_CONFIG_REDDIT=
AUTH_CONFIG_GOOGLESHEETS=
AUTH_CONFIG_YOUTUBE=

# Optional — connected account IDs for default routing
WHATSAPP_PHONE_NUMBER_ID=
INSTAGRAM_DEFAULT_PSID=
